# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/github_time_machine

# ── GitHub (optional — raises rate limits from 60 to 5000 req/hr) ─────────
GITHUB_TOKEN=ghp_your_token_here

# ── AI Provider (choose one) ────────────────────────
AI_PROVIDER=gemini               # "gemini" or "openai"
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# ── App settings ─────────────────────────────────────
SECRET_KEY=change_me_in_production_please
ENVIRONMENT=development          # development | production
REPO_CLONE_DIR=/tmp/repos        # where repos are cloned to disk
MAX_COMMITS=10000                # cap for large repos
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
